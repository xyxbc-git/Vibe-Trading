{
  "name": "jarvis-terminal",
  "version": "1.0.0",
  "description": "贾维斯桌面交易终端 — AI 加密货币交易助手",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron electron/main.mjs\"",
    "dev:vite": "vite",
    "dev:electron": "NODE_ENV=development electron electron/main.mjs",
    "build": "vite build",
    "build:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview",
    "lint": "eslint src/",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "author": "JARVIS",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "clsx": "^2.1.0",
    "framer-motion": "^11.15.0",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.jarvis.terminal",
    "productName": "JARVIS Terminal",
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  }
}
